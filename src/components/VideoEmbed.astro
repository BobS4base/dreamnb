---
export interface Props {
  bvid: string;
  title?: string;
  width?: string;
  height?: string;
}

const { bvid, title = 'Bilibili 视频', width = '100%', height = '400' } = Astro.props;
---

<div class="video-wrapper">
  <iframe
    src={`//player.bilibili.com/player.html?bvid=${bvid}&page=1&autoplay=0&high_quality=1`}
    width={width}
    height={height}
    title={title}
    allowfullscreen
    scrolling="no"
    frameborder="0"
    sandbox="allow-top-navigation allow-same-origin allow-forms allow-scripts allow-popups"
  ></iframe>
</div>

<style>
  .video-wrapper {
    position: relative;
    width: 100%;
    margin: 1.5rem 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .video-wrapper iframe {
    display: block;
    border-radius: 8px;
  }
</style>