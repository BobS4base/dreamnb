---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, coverImage, tags } = post.data;
---

<article class="blog-card glass">
  <a href={`/blog/${post.slug}`} class="card-link">
    {coverImage && (
      <div class="card-image">
        <img src={coverImage} alt={title} loading="lazy" />
      </div>
    )}
    <div class="card-body">
      <h2 class="card-title">{title}</h2>
      <p class="card-desc">{description}</p>
      <div class="card-meta">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          })}
        </time>
        {tags.length > 0 && (
          <span class="card-tags">
            {tags.map(t => <span class="card-tag">{t}</span>)}
          </span>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .blog-card {
    overflow: hidden;
    padding: 0;
    border-radius: 10px;
  }

  .blog-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }

  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .blog-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-body {
    padding: 0.9rem 1rem 1rem;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
    color: var(--color-text-glass);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0 0 0.6rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .card-tag {
    padding: 0.1rem 0.5rem;
    background: var(--color-accent-glass);
    border-radius: 4px;
    font-size: 0.72rem;
    color: var(--color-accent);
  }
</style>