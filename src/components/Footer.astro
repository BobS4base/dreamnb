---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <p class="copyright">&copy; {year} SpongeBob All Rights Reserved</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem;
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: var(--content-width);
    margin: 0 auto;
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .copyright {
    margin: 0;
  }
</style>