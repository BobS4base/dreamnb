---
const paths = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '博客' },
  { href: '/guestbook', label: '留言板' },
  { href: '/about', label: '关于' },
];
---

<header class="header">
  <nav class="nav">
    <a href="/" class="logo">dreamnb<span class="logo-suffix"> 有梦想，就是牛逼</span></a>
    <ul class="nav-links">
      {paths.map(p => (
        <li><a href={p.href} class="nav-link">{p.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
  }

  .logo {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .logo-suffix {
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .nav-links {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: block;
    padding: 0.4rem 0.7rem;
    text-decoration: none;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-code-bg);
    text-decoration: none;
  }
</style>