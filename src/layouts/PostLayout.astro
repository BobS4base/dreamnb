---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, coverImage, tags } = post.data;
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </div>
      {coverImage && (
        <img
          class="post-cover"
          src={coverImage}
          alt={title}
          loading="lazy"
        />
      )}
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-title {
    font-size: 2rem;
    line-height: 1.3;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    font-size: 0.8rem;
    background: var(--color-bg-muted);
    border-radius: 4px;
    color: var(--color-text-muted);
  }

  .post-cover {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 8px;
    margin-top: 1rem;
  }

  .post-content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-content :global(h3) {
    font-size: 1.2rem;
    margin: 1.5rem 0 0.75rem;
  }

  .post-content :global(p) {
    margin: 0 0 1.25rem;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .post-content :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-left: 4px solid var(--color-accent);
    background: var(--color-bg-muted);
    border-radius: 0 6px 6px 0;
    color: var(--color-text-muted);
  }

  .post-content :global(ul), .post-content :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .post-content :global(iframe) {
    border-radius: 8px;
    margin: 1.5rem 0;
    border: none;
  }

  .post-content :global(code) {
    padding: 0.15rem 0.4rem;
    background: var(--color-bg-muted);
    border-radius: 3px;
    font-size: 0.9em;
  }

  .post-content :global(pre) {
    background: var(--color-bg-muted);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
  }
</style>