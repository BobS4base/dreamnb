---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
blogPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="首页">
  <section class="hero">
    <h1 class="hero-title">你好，我是 <span class="highlight">dreamnb</span></h1>
    <p class="hero-desc">
      有梦想，就是牛逼。<br />
      这里是我的个人网络空间。
    </p>
  </section>

  <section class="section">
    <div class="section-header">
      <h2 class="section-title">📝 随笔博客</h2>
      <a href="/blog" class="section-more">查看全部 →</a>
    </div>
    {blogPosts.length > 0 ? (
      <div class="grid blog-grid">
        {blogPosts.map(post => <BlogCard post={post} />)}
      </div>
    ) : (
      <p class="empty">还没有文章，敬请期待。</p>
    )}
  </section>

  <section class="section">
    <div class="section-header">
      <h2 class="section-title">📹 视频</h2>
    </div>
    <div class="video-grid">
      <div class="video-card">
        <div class="video-wrapper">
          <iframe src="//player.bilibili.com/player.html?bvid=BV1NvNK6GEuG&page=1&autoplay=0&high_quality=1" width="100%" height="100%" allowfullscreen="allowfullscreen" scrolling="no"></iframe>
        </div>
        <p class="video-title">我的视频</p>
      </div>
    </div>
    <div class="video-more">
      <a href="https://space.bilibili.com/1862853635" target="_blank" rel="noopener" class="btn">去 Bilibili 关注我 →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .hero-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
    line-height: 1.3;
    color: var(--color-text);
  }

  .highlight {
    color: var(--color-accent);
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  .section {
    margin: 3rem 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.4rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text);
  }

  .section-more {
    font-size: 0.9rem;
    color: var(--color-accent);
    text-decoration: none;
  }

  .section-more:hover {
    text-decoration: underline;
  }

  .grid {
    display: grid;
    gap: 1.25rem;
  }

  .blog-grid {
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: 2rem 0;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 1.5rem;
  }

  .video-card {
    border-radius: 10px;
    overflow: hidden;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-bg-muted);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-title {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0.5rem 0 0;
    text-align: center;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 2rem 0 1.5rem;
    }

    .hero-title {
      font-size: 1.8rem;
    }

    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>