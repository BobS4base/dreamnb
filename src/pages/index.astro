---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
blogPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="首页">
  <div class="dashboard">
    <!-- 左侧：随笔博客 -->
    <div class="panel glass">
      <div class="glass-titlebar">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
        <span class="title-text">📝 随笔博客</span>
      </div>
      <div class="glass-body panel-body">
        {blogPosts.length > 0 ? (
          <div class="blog-list">
            {blogPosts.map(post => <BlogCard post={post} />)}
          </div>
        ) : (
          <p class="empty">还没有文章，敬请期待。</p>
        )}
      </div>
    </div>

    <!-- 右侧：视频 -->
    <div class="panel glass">
      <div class="glass-titlebar">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
        <span class="title-text">📹 视频</span>
      </div>
      <div class="glass-body panel-body">
        <div class="video-list">
          <div class="video-item glass">
            <div class="video-wrapper">
              <iframe src="//player.bilibili.com/player.html?bvid=BV1yXLA6tE9g&page=1&autoplay=0&high_quality=1" width="100%" height="100%" allowfullscreen scrolling="no"></iframe>
            </div>
            <p class="video-title">我的视频</p>
          </div>
        </div>
        <div class="video-footer">
          <a href="https://space.bilibili.com/1862853635" target="_blank" rel="noopener" class="bili-link">去 Bilibili 关注我 →</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .dashboard {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.5rem 0;
  }

  .panel {
    overflow: hidden;
  }

  .panel-body {
    max-height: 70vh;
    overflow-y: auto;
    padding: 0.75rem;
  }

  .panel-body::-webkit-scrollbar {
    width: 5px;
  }

  .panel-body::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.12);
    border-radius: 3px;
  }

  /* ===== 博客列表 ===== */
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ===== 视频列表 ===== */
  .video-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .video-item {
    overflow: hidden;
    padding: 0;
    border-radius: 10px;
  }

  .video-item:hover {
    transform: none;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.1);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-title {
    font-size: 0.85rem;
    color: var(--color-text-glass);
    padding: 0.6rem 0.75rem;
    margin: 0;
    text-align: center;
    font-weight: 500;
  }

  .video-footer {
    text-align: center;
    padding: 0.5rem 0 0.25rem;
  }

  .bili-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.4rem 1rem;
    border-radius: 6px;
    background: var(--color-accent-glass);
    transition: background 0.2s;
  }

  .bili-link:hover {
    background: color-mix(in srgb, var(--color-accent) 25%, transparent);
  }

  /* ===== 响应式 ===== */
  @media (max-width: 860px) {
    .dashboard {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .panel-body {
      max-height: none;
    }
  }

  @media (max-width: 480px) {
    .dashboard {
      padding: 0;
    }
  }
</style>