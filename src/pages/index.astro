---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
blogPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="dreamnb" description="dreamnb 的个人博客">
  <h1 class="page-title">博客</h1>

  {blogPosts.length > 0 ? (
    <div class="blog-list">
      {blogPosts.map(post => {
        const { title, pubDate } = post.data;
        return (
          <a href={`/blog/${post.slug}`} class="blog-item">
            <time class="blog-item-date" datetime={pubDate.toISOString()}>
              {pubDate.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
              })}
            </time>
            <span class="blog-item-title">{title}</span>
          </a>
        );
      })}
    </div>
  ) : (
    <p class="empty">还没有文章，敬请期待。</p>
  )}
</BaseLayout>