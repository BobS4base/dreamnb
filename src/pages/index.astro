---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
blogPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const postCount = blogPosts.length;
---

<BaseLayout title="home" description="dreamnb 的个人博客">
  <!-- ===== QQ空间风格 — 个人简介 ===== -->
  <div class="profile">
    <div class="profile-avatar">
      <img
        src="https://q1.qlogo.cn/g?b=qq&nk=310821993&s=640"
        alt="头像"
        loading="lazy"
      />
    </div>
    <div class="profile-info">
      <h1 class="profile-name">dreamnb</h1>
      <p class="profile-sig">有梦想，就是牛逼</p>
    </div>
    <div class="profile-stats">
      <div class="profile-stat">
        <span class="profile-stat-num">{postCount}</span>
        <span class="profile-stat-label">文章</span>
      </div>
    </div>
  </div>

  <!-- ===== 博客文章 ===== -->
  {postCount > 0 ? (
    <div class="blog-list">
      {blogPosts.map(post => {
        const { title, pubDate } = post.data;
        return (
          <a href={`/blog/${post.slug}`} class="blog-item">
            <time class="blog-item-date" datetime={pubDate.toISOString()}>
              {pubDate.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
              })}
            </time>
            <span class="blog-item-title">{title}</span>
          </a>
        );
      })}
    </div>
  ) : (
    <p class="empty">还没有文章，敬请期待。</p>
  )}
</BaseLayout>