---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
blogPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="首页">
  <div class="dashboard">
    <!-- 左侧：随笔博客 -->
    <div class="panel glass">
      <div class="glass-titlebar">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
        <span class="title-text">📝 随笔博客</span>
      </div>
      <div class="glass-body panel-body">
        {blogPosts.length > 0 ? (
          <div class="blog-list">
            {blogPosts.map(post => <BlogCard post={post} />)}
          </div>
        ) : (
          <p class="empty">还没有文章，敬请期待。</p>
        )}
      </div>
    </div>

    <!-- 右侧：QQ空间 -->
    <div class="panel glass">
      <div class="glass-titlebar">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
        <span class="title-text">💬 QQ空间</span>
      </div>
      <div class="glass-body panel-body qzone-body">
        <div class="qzone-card glass">
          <div class="qzone-avatar">
            <img src="https://q1.qlogo.cn/g?b=qq&nk=310821993&s=640" alt="QQ头像" />
          </div>
          <div class="qzone-info">
            <h3>我的QQ空间</h3>
            <p class="qzone-uin">QQ: 310821993</p>
          </div>
        </div>
        <div class="qzone-footer">
          <a href="https://user.qzone.qq.com/310821993" target="_blank" rel="noopener" class="qzone-link">进入我的QQ空间 →</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .dashboard {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.5rem 0;
  }

  .panel {
    overflow: hidden;
  }

  .panel-body {
    max-height: 70vh;
    overflow-y: auto;
    padding: 0.75rem;
  }

  .panel-body::-webkit-scrollbar {
    width: 5px;
  }

  .panel-body::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.12);
    border-radius: 3px;
  }

  /* ===== 博客列表 ===== */
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ===== QQ空间卡片 ===== */
  .qzone-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    min-height: 280px;
  }

  .qzone-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem 2rem 1.5rem;
    border-radius: 16px;
    width: 100%;
    max-width: 280px;
  }

  .qzone-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .qzone-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .qzone-info {
    text-align: center;
  }

  .qzone-info h3 {
    margin: 0 0 0.3rem;
    font-size: 1.1rem;
    color: var(--color-text-glass);
  }

  .qzone-uin {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-glass);
    opacity: 0.7;
  }

  .qzone-footer {
    text-align: center;
  }

  .qzone-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.5rem 1.5rem;
    border-radius: 8px;
    background: var(--color-accent-glass);
    transition: background 0.2s, transform 0.15s;
  }

  .qzone-link:hover {
    background: color-mix(in srgb, var(--color-accent) 25%, transparent);
    transform: scale(1.05);
  }

  /* ===== 响应式 ===== */
  @media (max-width: 860px) {
    .dashboard {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .panel-body {
      max-height: none;
    }
  }

  @media (max-width: 480px) {
    .dashboard {
      padding: 0;
    }
  }
</style>