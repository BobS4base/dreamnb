---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="留言板" description="留下你的想法">
  <h1 class="sec-title" style="font-size:1.5rem; border-bottom:2px solid var(--color-text); padding-bottom:0.75rem; margin-bottom:1.5rem;">留言板 💬</h1>

  <form class="gb-form" id="guestbookForm">
    <div class="gb-field">
      <label for="gbName">昵称（可选）</label>
      <input type="text" id="gbName" name="name" placeholder="你的名字" maxlength="50" />
    </div>
    <div class="gb-field">
      <label for="gbContent">留言内容 <span class="gb-req">*</span></label>
      <textarea id="gbContent" name="content" rows="5" placeholder="写点什么吧…" maxlength="20000" required></textarea>
      <span class="gb-counter" id="charCounter">0 / 20000</span>
    </div>
    <button type="submit" class="gb-submit" id="submitBtn">发表留言</button>
    <p class="gb-status" id="gbStatus"></p>
  </form>

  <hr class="sec-divider" />

  <div id="messageList" class="gb-list">
    <p class="empty">加载中…</p>
  </div>

  <div class="gb-loadmore" id="loadMoreWrap" style="display:none">
    <button id="loadMoreBtn" class="gb-loadmore-btn">加载更多</button>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('guestbookForm') as HTMLFormElement;
  const nameInput = document.getElementById('gbName') as HTMLInputElement;
  const contentInput = document.getElementById('gbContent') as HTMLTextAreaElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const statusEl = document.getElementById('gbStatus') as HTMLParagraphElement;
  const messageList = document.getElementById('messageList') as HTMLDivElement;
  const loadMoreWrap = document.getElementById('loadMoreWrap') as HTMLDivElement;
  const loadMoreBtn = document.getElementById('loadMoreBtn') as HTMLButtonElement;
  const charCounter = document.getElementById('charCounter') as HTMLSpanElement;

  let currentPage = 1;
  let totalMessages = 0;
  let isLoading = false;

  contentInput.addEventListener('input', () => {
    const len = contentInput.value.length;
    charCounter.textContent = `${len} / 20000`;
    charCounter.style.color = len > 20000 ? '#e53e3e' : '#888';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const content = contentInput.value.trim();
    if (!content) {
      statusEl.textContent = '请填写留言内容';
      statusEl.style.color = '#e53e3e';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = '提交中…';
    statusEl.textContent = '';

    try {
      const res = await fetch('/api/guestbook', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: nameInput.value.trim() || '匿名',
          content,
        }),
      });
      const data = await res.json();
      if (data.success) {
        statusEl.textContent = '留言成功！';
        statusEl.style.color = '#38a169';
        contentInput.value = '';
        nameInput.value = '';
        charCounter.textContent = '0 / 20000';
        currentPage = 1;
        loadMessages(true);
      } else {
        statusEl.textContent = data.error || '提交失败';
        statusEl.style.color = '#e53e3e';
      }
    } catch {
      statusEl.textContent = '网络错误，请稍后再试';
      statusEl.style.color = '#e53e3e';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = '发表留言';
    }
  });

  async function loadMessages(reset = false) {
    if (isLoading) return;
    isLoading = true;

    try {
      const res = await fetch(`/api/guestbook?page=${currentPage}`);
      const data = await res.json();
      totalMessages = data.total || 0;

      if (reset) messageList.innerHTML = '';

      if (data.messages && data.messages.length > 0) {
        data.messages.forEach((msg: any) => {
          const el = document.createElement('div');
          el.className = 'gb-message';
          el.innerHTML = `
            <div class="gb-msg-header">
              <span class="gb-msg-name">${escapeHtml(msg.name)}</span>
              <span class="gb-msg-time">${msg.created_at}</span>
            </div>
            <div class="gb-msg-content">${escapeHtml(msg.content).replace(/\n/g, '<br>')}</div>
          `;
          messageList.appendChild(el);
        });

        const loaded = reset ? data.messages.length : messageList.querySelectorAll('.gb-message').length;
        loadMoreWrap.style.display = loaded < totalMessages ? 'block' : 'none';
      } else {
        if (reset) messageList.innerHTML = '<p class="empty">还没有留言，来写第一条吧！</p>';
        loadMoreWrap.style.display = 'none';
      }
    } catch {
      if (reset) messageList.innerHTML = '<p class="empty">加载留言失败，请刷新页面重试</p>';
    } finally {
      isLoading = false;
    }
  }

  loadMoreBtn.addEventListener('click', () => {
    currentPage++;
    loadMessages();
  });

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  loadMessages(true);
</script>

<style>
  .sec-divider {
    border: none;
    border-top: 2px solid var(--color-text);
    margin: 2rem 0;
  }

  .gb-form { margin-bottom: 2rem; }
  .gb-field { margin-bottom: 1rem; }

  .gb-field label {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  .gb-req { color: #e53e3e; }

  .gb-field input,
  .gb-field textarea {
    width: 100%;
    padding: 0.6rem 0.75rem;
    font-size: 0.95rem;
    font-family: var(--font-sans);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .gb-field input:focus,
  .gb-field textarea:focus { border-color: var(--color-accent); }
  .gb-field textarea { resize: vertical; min-height: 80px; }

  .gb-counter {
    display: block;
    text-align: right;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .gb-submit {
    padding: 0.6rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: #fff;
    background: var(--color-accent);
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .gb-submit:hover { background: var(--color-accent-hover); }
  .gb-submit:disabled { opacity: 0.6; cursor: not-allowed; }
  .gb-status { margin-top: 0.5rem; font-size: 0.85rem; }

  .gb-list { display: flex; flex-direction: column; gap: 1rem; }

  .gb-message {
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
  }

  .gb-msg-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .gb-msg-name { font-weight: 600; font-size: 0.9rem; color: var(--color-accent); }
  .gb-msg-time { font-size: 0.78rem; color: var(--color-text-muted); }

  .gb-msg-content {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--color-text);
    word-break: break-word;
    white-space: pre-wrap;
  }

  .gb-loadmore { text-align: center; margin-top: 1.5rem; }

  .gb-loadmore-btn {
    padding: 0.5rem 1.5rem;
    font-size: 0.9rem;
    color: var(--color-accent);
    background: transparent;
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .gb-loadmore-btn:hover { background: var(--color-accent); color: #fff; }
</style>