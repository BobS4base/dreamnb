---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PortfolioCard from '../../components/PortfolioCard.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('portfolio');
items.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="作品集" description="我的创作与项目作品">
  <section>
    <h1 class="page-title">作品集</h1>
    <p class="page-desc">这里展示我的创作与项目作品。</p>

    {items.length > 0 ? (
      <div class="grid">
        {items.map(item => <PortfolioCard item={item} />)}
      </div>
    ) : (
      <p class="empty">还没有作品，敬请期待。</p>
    )}
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }

  .page-desc {
    color: var(--color-text-muted);
    margin: 0 0 2rem;
    font-size: 1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: 3rem 0;
  }
</style>