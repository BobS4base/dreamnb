---
import BaseLayout from '../layouts/BaseLayout.astro';

const videos = [
  {
    id: 'BV1rx411U7ux',
    title: 'Alan Walker - Faded',
    caption: 'Alan Walker - Faded (MV · 中英字幕)',
  },
  {
    id: 'BV1rsRsByEdT',
    title: '中东宝宝',
    caption: '中东宝宝',
  },
];
---

<BaseLayout title="视频欣赏">
  <div class="video-page">
    <h1 class="video-title">🎬 视频欣赏</h1>
    <div class="video-container" id="videoContainer">
      <div class="video-viewport">
        {videos.map((v, i) => (
          <div class="video-slide" data-index={i}>
            <div class="video-wrapper">
              <iframe
                src={"//player.bilibili.com/player.html?bvid=" + v.id + "&page=1&autoplay=0&high_quality=1"}
                allowfullscreen="allowfullscreen"
                width="100%"
                height="100%"
                frameborder="0"
                sandbox="allow-top-navigation allow-same-origin allow-forms allow-scripts allow-popups"
                loading={i === 0 ? 'eager' : 'lazy'}
              ></iframe>
            </div>
          </div>
        ))}
        <button class="video-arrow arrow-left" id="prevBtn" aria-label="上一个">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="video-arrow arrow-right" id="nextBtn" aria-label="下一个">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
        <div class="video-counter" id="counter">1 / {videos.length}</div>
      </div>
      <div class="video-info" id="info">
        <p class="video-caption" id="caption">{videos[0].caption}</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .video-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .video-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .video-container {
    position: relative;
  }

  .video-viewport {
    position: relative;
    overflow: hidden;
  }

  .video-slide {
    display: none;
  }

  .video-slide.active {
    display: block;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: none;
    background: rgba(0,0,0,0.06);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.4s ease, background 0.2s ease;
  }

  .video-arrow.hidden { opacity: 0; pointer-events: none; }
  .video-arrow:hover { background: var(--color-code-bg); }
  .arrow-left { left: 10px; }
  .arrow-right { right: 10px; }

  .video-counter {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-family: var(--font-mono);
    background: rgba(0,0,0,0.06);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 4px 14px;
    border-radius: 20px;
    opacity: 1;
    transition: opacity 0.4s ease;
  }

  .video-counter.hidden { opacity: 0; }

  .video-info {
    padding: 16px 0 0;
    text-align: center;
    opacity: 1;
    transition: opacity 0.4s ease;
  }

  .video-info.hidden { opacity: 0; }

  .video-caption {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .video-copyright {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin: 8px 0 0;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .video-arrow { width: 42px; height: 42px; }
    .video-arrow svg { width: 22px; height: 22px; }
    .arrow-left { left: 10px; }
    .arrow-right { right: 10px; }
    .video-counter { bottom: 12px; }
    .video-copyright { font-size: 0.65rem; }
  }
</style>

<script>
(function() {
  var slides = document.querySelectorAll('.video-slide');
  var prevBtn = document.getElementById('prevBtn');
  var nextBtn = document.getElementById('nextBtn');
  var counter = document.getElementById('counter');
  var caption = document.getElementById('caption');

  var captions = [
    'Alan Walker - Faded (MV · 中英字幕)',
    '中东宝宝',
  ];

  var cur = 0;

  // 保存每个 iframe 的原始 src
  var iframes = [];
  for (var j = 0; j < slides.length; j++) {
    var iframe = slides[j].querySelector('iframe');
    iframes.push(iframe);
    iframe.setAttribute('data-src', iframe.src);
  }

  function show(i) {
    for (var j = 0; j < slides.length; j++) {
      if (j === i) {
        slides[j].classList.add('active');
        // 恢复当前视频的 src
        iframes[j].src = iframes[j].getAttribute('data-src');
      } else {
        slides[j].classList.remove('active');
        // 停止非当前视频：清空 src 以停止播放
        iframes[j].src = '';
      }
    }
    counter.textContent = (i + 1) + ' / ' + slides.length;
    caption.textContent = captions[i];
  }

  function nextSlide() { cur = (cur + 1) % slides.length; show(cur); }
  function prevSlide() { cur = (cur - 1 + slides.length) % slides.length; show(cur); }

  prevBtn.addEventListener('click', function(e) { e.stopPropagation(); prevSlide(); });
  nextBtn.addEventListener('click', function(e) { e.stopPropagation(); nextSlide(); });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft') prevSlide();
    else if (e.key === 'ArrowRight') nextSlide();
  });

  var tx = 0;
  document.querySelector('.video-viewport').addEventListener('touchstart', function(e) {
    tx = e.changedTouches[0].screenX;
  }, { passive: true });
  document.querySelector('.video-viewport').addEventListener('touchend', function(e) {
    var diff = tx - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) nextSlide(); else prevSlide();
    }
  }, { passive: true });

  show(0);
})();
</script>