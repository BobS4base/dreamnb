const galleryDir = path.resolve('public/uploads/images/gallery');
const files = fs.readdirSync(galleryDir)
  .filter(f => /\.(jpg|jpeg|png|gif|webp)$/i.test(f))
  .sort();

const paintings = files.map((f, i) => {
  const named = namedPaintings[f];
  return {
    id: i + 1,
    title: named.title,
    titleCn: named.titleCn,
    artist: named.artist,
    year: named.year,
    location: named.location,
    image: '/uploads/images/gallery/' + f,
  };
});

// 在 frontmatter 中预生成 JSON，避免模板表达式解析问题
const paintingsJson = JSON.stringify(paintings.map(p => ({
  title: p.titleCn ? (p.title + ' · ' + p.titleCn) : p.title,
  artist: p.artist,
  year: p.year,
  location: p.location,
  image: p.image,
})));
---

<BaseLayout title="作品欣赏">
  <div class="gallery-page">
    <div class="gallery-container" id="gallery">
      <div class="gallery-viewport" id="viewport">
        {paintings.map((p, i) => (
          <div class="gallery-slide" data-index={i}>
            <img
              src={p.image}
              alt={p.title}
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
        <button class="gallery-arrow arrow-left" id="prevBtn" aria-label="上一张">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="gallery-arrow arrow-right" id="nextBtn" aria-label="下一张">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
        <div class="gallery-counter" id="counter">1 / {paintings.length}</div>
      </div>

      <div class="gallery-info" id="info">
        <h2 class="info-title" id="infoTitle">{paintings[0].title}</h2>
        <p class="info-detail" id="infoDetail">{paintings[0].artist != 'Unknown' ? paintings[0].artist + (paintings[0].year ? (' &middot; ' + paintings[0].year) : '') : ''}</p>
        <p class="info-location" id="infoLocation">{paintings[0].location}</p>
        <p class="gallery-copyright">&copy; 2026 SpongeBob All Rights Reserved</p>
      </div>
      <script id="paintings-data" type="application/json" set:html={paintingsJson}></script>
    </div>
  </div>
</BaseLayout>

<style>
  .gallery-page {
    position: fixed;
    top: 56px;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    background: #000;
    z-index: 100;
  }
  .gallery-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .gallery-viewport {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0a0a;
    min-height: 0;
  }
  .gallery-slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  .gallery-slide.active {
    opacity: 1;
    pointer-events: auto;
  }
  .gallery-slide img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
  }
  .gallery-slide img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
  }
  .gallery-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.4s ease, background 0.2s ease;
  }
  .gallery-arrow.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .gallery-arrow:hover {
    background: rgba(255,255,255,0.3);
  }
  .arrow-left { left: 20px; }
  .arrow-right { right: 20px; }
  .gallery-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    color: rgba(255,255,255,0.7);
    font-size: 0.85rem;
    font-family: var(--font-mono);
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 4px 14px;
    border-radius: 20px;
    opacity: 1;
    transition: opacity 0.4s ease;
  }
  .gallery-counter.hidden { opacity: 0; }
  .gallery-info {
    flex-shrink: 0;
    padding: 16px 24px 20px;
    background: #111;
    color: #ddd;
    text-align: center;
    border-top: 1px solid #222;
    opacity: 1;
    transition: opacity 0.4s ease;
  }
  .gallery-info.hidden { opacity: 0; }
  .info-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 4px;
    letter-spacing: 0.5px;
  }
  .info-detail { font-size: 0.9rem; color: #aaa; margin: 0 0 2px; }
  .info-location { font-size: 0.8rem; color: #777; margin: 0; }
  .gallery-copyright {
    font-size: 0.65rem;
    color: #555;
    margin: 10px 0 0;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .gallery-arrow { width: 42px; height: 42px; }
    .gallery-arrow svg { width: 22px; height: 22px; }
    .arrow-left { left: 10px; }
    .arrow-right { right: 10px; }
    .gallery-info { padding: 12px 16px 16px; }
    .info-title { font-size: 1rem; }
    .info-detail { font-size: 0.8rem; }
    .info-location { font-size: 0.75rem; }
  }
</style>

<script>
(function() {
  const slides = document.querySelectorAll('.gallery-slide');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const counter = document.getElementById('counter');
  const infoTitle = document.getElementById('infoTitle');
  const infoDetail = document.getElementById('infoDetail');
  const infoLocation = document.getElementById('infoLocation');
  const infoBox = document.querySelector('.gallery-info');
  const counterEl = document.querySelector('.gallery-counter');
  const viewport = document.getElementById('viewport');

  // 从隐藏 div 读取画作数据
  const paintings = JSON.parse(document.getElementById('paintings-data').textContent);

  let current = 0;
  let hideTimer = null;
  const loaded = new Set();

  function preloadImage(src) {
    if (!src || loaded.has(src)) return;
    loaded.add(src);
    const img = new Image();
    img.src = src;
  }

  function preloadAdjacent(index) {
    const n = paintings.length;
    preloadImage(paintings[index].image);
    preloadImage(paintings[(index - 1 + n) % n].image);
    preloadImage(paintings[(index + 1) % n].image);
  }

  function handleImgError(img) {
    if (img.dataset.broken) return;
    img.dataset.broken = '1';
    img.style.display = 'none';
    var fallback = document.createElement('div');
    fallback.textContent = '\u274c \u52a0\u8f7d\u5931\u8d25';
    fallback.style.cssText = 'color:#666;font-size:1.2rem;text-align:center;padding:2rem;';
    img.parentElement.appendChild(fallback);
  }

  function showSlide(index) {
    slides.forEach((s, i) => s.classList.toggle('active', i === index));
    counter.textContent = (index + 1) + ' / ' + paintings.length;
    infoTitle.textContent = paintings[index].title;
    infoDetail.innerHTML = paintings[index].artist ? (paintings[index].artist !== 'Unknown' ? paintings[index].artist + (paintings[index].year ? (' \u00b7 ' + paintings[index].year) : '') : '') : '';
    infoLocation.textContent = paintings[index].location;
    preloadAdjacent(index);
  }

  function next() {
    current = (current + 1) % paintings.length;
    showSlide(current);
    resetHideTimer();
  }

  function prev() {
    current = (current - 1 + paintings.length) % paintings.length;
    showSlide(current);
    resetHideTimer();
  }

  function showUI() {
    document.querySelectorAll('.gallery-arrow').forEach(el => el.classList.remove('hidden'));
    infoBox.classList.remove('hidden');
    counterEl.classList.remove('hidden');
  }

  function hideUI() {
    document.querySelectorAll('.gallery-arrow').forEach(el => el.classList.add('hidden'));
    infoBox.classList.add('hidden');
    counterEl.classList.add('hidden');
  }

  function resetHideTimer() {
    showUI();
    if (hideTimer) clearTimeout(hideTimer);
    hideTimer = setTimeout(hideUI, 4000);
  }

  function onUserActivity() { resetHideTimer(); }

  prevBtn.addEventListener('click', function(e) { e.stopPropagation(); prev(); });
  nextBtn.addEventListener('click', function(e) { e.stopPropagation(); next(); });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft') prev();
    else if (e.key === 'ArrowRight') next();
  });

  var touchStartX = 0;
  viewport.addEventListener('touchstart', function(e) {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  viewport.addEventListener('touchend', function(e) {
    var diff = touchStartX - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) next();
      else prev();
    }
  }, { passive: true });

  document.addEventListener('mousemove', onUserActivity);
  document.addEventListener('touchstart', onUserActivity, { passive: true });

  slides.forEach(function(slide) {
    var img = slide.querySelector('img');
    if (img) {
      img.addEventListener('error', function() { handleImgError(this); });
      if (img.complete && (img.naturalWidth === 0 || img.naturalHeight === 0)) {
        handleImgError(img);
      }
    }
  });

  showSlide(0);
  resetHideTimer();
})();
</script>
