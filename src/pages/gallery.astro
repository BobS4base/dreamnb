<BaseLayout title="作品欣赏">
  <div class="gallery-page">
    <div class="gallery-container" id="gallery">
      <div class="gallery-viewport">
        {paintings.map((p, i) => (
          <div class="gallery-slide" data-index={i}>
            <img src={p.image} alt={p.title} loading={i === 0 ? 'eager' : 'lazy'} />
          </div>
        ))}
        <button class="gallery-arrow arrow-left" id="prevBtn" aria-label="上一张">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="gallery-arrow arrow-right" id="nextBtn" aria-label="下一张">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
        <div class="gallery-counter" id="counter">1 / 194</div>
      </div>
      <div class="gallery-info" id="info">
        <h2 class="info-title" id="infoTitle">{paintings[0].title}</h2>
        <p class="info-detail" id="infoDetail">{paintings[0].artist} &middot; {paintings[0].year}</p>
        <p class="info-location" id="infoLocation">{paintings[0].location}</p>
        <p class="info-copyright">Artworks belong to their respective artists &amp; estates</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .gallery-page { position: fixed; top: 56px; left: 0; right: 0; bottom: 0; display: flex; flex-direction: column; background: var(--color-bg); z-index: 100; }
  .gallery-container { flex: 1; display: flex; flex-direction: column; position: relative; overflow: hidden; }
  .gallery-viewport { flex: 1; position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; background: var(--color-bg); min-height: 0; }
  .gallery-slide { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.5s ease; pointer-events: none; }
  .gallery-slide.active { opacity: 1; pointer-events: auto; }
  .gallery-slide img { max-width: 100%; max-height: 100%; object-fit: contain; user-select: none; }
  .gallery-arrow { position: absolute; top: 50%; transform: translateY(-50%); z-index: 10; width: 52px; height: 52px; border-radius: 50%; border: none; background: rgba(0,0,0,0.06); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); color: var(--color-text); cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 1; transition: opacity 0.4s ease, background 0.2s ease; }
  .gallery-arrow.hidden { opacity: 0; pointer-events: none; }
  .gallery-arrow:hover { background: var(--color-code-bg); }
  .arrow-left { left: 20px; } .arrow-right { right: 20px; }
  .gallery-counter { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); z-index: 10; color: var(--color-text-muted); font-size: 0.85rem; font-family: var(--font-mono); background: rgba(0,0,0,0.06); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); padding: 4px 14px; border-radius: 20px; opacity: 1; transition: opacity 0.4s ease; }
  .gallery-counter.hidden { opacity: 0; }
  .gallery-info { flex-shrink: 0; padding: 16px 24px 20px; background: var(--color-bg); color: var(--color-text); text-align: center; border-top: 1px solid var(--color-border); opacity: 1; transition: opacity 0.4s ease; }
  .gallery-info.hidden { opacity: 0; }
  .info-title { font-size: 1.15rem; font-weight: 600; color: var(--color-text); margin: 0 0 4px; }
  .info-detail { font-size: 0.9rem; color: var(--color-text-muted); margin: 0 0 2px; }
  .info-location { font-size: 0.8rem; color: var(--color-text-muted); margin: 0; }
  .info-copyright { font-size: 0.7rem; color: var(--color-text-muted); margin: 8px 0 0; opacity: 0.6; }
  @media (max-width: 768px) {
    .gallery-arrow { width: 42px; height: 42px; }
    .gallery-arrow svg { width: 22px; height: 22px; }
    .arrow-left { left: 10px; } .arrow-right { right: 10px; }
    .gallery-info { padding: 12px 16px 16px; }
    .info-title { font-size: 1rem; } .info-detail { font-size: 0.8rem; } .info-location { font-size: 0.75rem; }
    .info-copyright { font-size: 0.65rem; }
  }
</style>

