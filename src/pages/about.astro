---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于" description="关于海绵宝宝">
  <div class="about-container">
    <div class="about-card glass">
      <div class="glass-titlebar">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
        <span class="title-text">👋 关于我</span>
      </div>
      <div class="glass-body about-body">
        <p class="about-greeting">你好，我是 <strong>海绵宝宝</strong> 🧽</p>

        <div class="about-links">
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem 0;
  }

  .about-card {
    width: 100%;
    max-width: 480px;
    overflow: hidden;
  }

  .about-body {
    padding: 2rem;
    text-align: center;
  }

  .about-greeting {
    font-size: 1.3rem;
    color: var(--color-text-glass);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .about-greeting strong {
    color: var(--color-accent);
    font-size: 1.5rem;
  }

  .about-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .about-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.25rem;
    border-radius: 10px;
    text-decoration: none;
    color: var(--color-text-glass);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: all 0.2s;
  }

  .about-link:hover {
    transform: translateX(4px);
    background: var(--color-accent-glass);
    border-color: var(--color-accent);
  }

  .link-icon {
    font-size: 1.4rem;
    width: 2rem;
    text-align: center;
  }

  .link-text {
    flex: 1;
    font-size: 1rem;
    font-weight: 500;
    text-align: left;
  }

  .link-arrow {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    transition: transform 0.2s;
  }

  .about-link:hover .link-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 480px) {
    .about-body {
      padding: 1.5rem;
    }
  }
</style>