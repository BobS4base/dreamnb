---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="博客" description="生活随笔与技术分享">
  <h1 class="page-title">博客</h1>

  {posts.length > 0 ? (
    <div class="blog-list">
      {posts.map(post => {
        const { title, description, pubDate, tags } = post.data;
        return (
          <a href={`/blog/${post.slug}`} class="blog-item">
            <time class="blog-item-date" datetime={pubDate.toISOString()}>
              {pubDate.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
              })}
            </time>
            <div class="blog-item-info">
              <span class="blog-item-title">{title}</span>
              {tags.length > 0 && (
                <span class="blog-item-tags">
                  {tags.map(t => <span class="blog-item-tag">{t}</span>)}
                </span>
              )}
            </div>
          </a>
        );
      })}
    </div>
  ) : (
    <p class="empty">还没有文章，敬请期待。</p>
  )}
</BaseLayout>

<style>
  .blog-item-info {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .blog-item-tags {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .blog-item-tag {
    font-size: 0.72rem;
    padding: 0.05rem 0.4rem;
    background: var(--color-code-bg);
    border-radius: 3px;
    color: var(--color-text-muted);
  }
</style>